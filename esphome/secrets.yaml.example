# Copy this file to ``secrets.yaml`` next to ``esp32-dev-board.yaml`` and
# fill in your own values. ``secrets.yaml`` is gitignored — never commit it.

# Your Wi-Fi network.
wifi_ssid: "YourSSID"
wifi_password: "YourWiFiPassword"

# ESPHome native-API encryption key. Generate one at
# https://esphome.io/components/api.html#configuration-variables — or in the
# ESPHome dashboard via "Edit" -> "Configure" -> "Generate encryption key".
# Same key has to be entered in Home Assistant when adding the device.
api_encryption_key: "GENERATE_A_FRESH_BASE64_KEY"

# OTA update password — used by the ESPHome dashboard when re-flashing the
# board wirelessly. Pick any reasonably long random string.
ota_password: "GENERATE_A_RANDOM_PASSWORD"

# WPA2 password for the fallback AP that the board exposes when it cannot
# associate with the configured Wi-Fi. Used for recovery only.
ap_fallback_password: "GENERATE_AN_AP_PASSWORD"
